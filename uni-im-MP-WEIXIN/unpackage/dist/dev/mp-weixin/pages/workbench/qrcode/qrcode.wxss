.qrcode-query-page.data-v-d0ac87b1 {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}
.query-header.data-v-d0ac87b1 {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.query-header .input-group.data-v-d0ac87b1 {
  display: flex;
  align-items: center;
  gap: 15rpx;
}
.query-header .input-group .order-input.data-v-d0ac87b1 {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.query-header .input-group .order-input.data-v-d0ac87b1:focus {
  border-color: #007aff;
  outline: none;
}
.query-header .input-group .input-placeholder.data-v-d0ac87b1 {
  color: #999;
  font-size: 26rpx;
}
.query-header .input-group .query-btn.data-v-d0ac87b1 {
  width: 150rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #007aff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.query-header .input-group .query-btn.data-v-d0ac87b1:disabled {
  background-color: #ccc;
  color: #fff;
}
.query-header .input-group .query-btn.data-v-d0ac87b1:active:not(:disabled) {
  background-color: #0066cc;
}
.query-header .error-tip.data-v-d0ac87b1 {
  margin-top: 15rpx;
  color: #ff3b30;
  font-size: 24rpx;
  line-height: 1.5;
}
.content-container.data-v-d0ac87b1 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.qrcode-card.data-v-d0ac87b1 {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.qrcode-card .empty-state.data-v-d0ac87b1,
.qrcode-card .loading-state.data-v-d0ac87b1 {
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}
.qrcode-card .qrcode-img.data-v-d0ac87b1 {
  max-width: 100%;
  max-height: 600rpx;
  margin: 0 auto;
  border-radius: 8rpx;
}
.notice-card.data-v-d0ac87b1 {
  background-color: #fff8e1;
  padding: 25rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff9800;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.notice-card .notice-title.data-v-d0ac87b1 {
  display: block;
  font-size: 26rpx;
  color: #e65100;
  font-weight: 600;
  margin-bottom: 15rpx;
}
.notice-card .notice-content.data-v-d0ac87b1 {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}